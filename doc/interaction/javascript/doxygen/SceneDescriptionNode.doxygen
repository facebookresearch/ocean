
/**
 * This object wrapps an Ocean scene description node object.
 * A scene description node object can encapsulate arbitrary scene description nodes defined inside the Ocean framework.<br>
 * In this JavaScript plugin all type of scene description nodes can be accessed by the same JavaScript object type.<br>
 * Properties of scene description nodes can be changed or accessed using the field() or setField() functions.<br>
 * However, the developer should known which type of scene descriptoin node is wrapped to avoid usage of field not available for the kind of wrapped object.<br>
 * @see SceneDescriptionManager
 * @ingroup scenedescription
 */
struct SceneDescriptionNode
{
	/**
	 * Name of the scene description node.
	 * The name of a scene description node can be used to find the object with usage of the SceneDescriptionManager.
	 * The property has read and write access.<br>
	 *
	 * Example:
	 * @code
	 * // Predefined initialization function which is called once to initialize this script.
	 * function onOceanInitialize(engine, timestamp)
	 * {
	 *     var sceneNode = ocean.sceneDescription.findNode("NODE");
	 *
	 *     if (sceneNode.isInvalid())
	 *         ocean.warning("Could not found a scene description node with name 'NODE'");
	 *     else
	 *         ocean.info("The node has the following name: ", sceneNode.name);
	 * }
	 * @endcode
	 * @see SceneDescrptionManager::findNode().
	 */
	String name [get, set];

	/**
	 * Type of the scene description node.
	 * The type of a scene description node can be used to determine which type of Ocean framework object is wrapped by this JavaScript scene description node.<br>
	 * All possible node types depend on the used scene description plugin.<br>
	 * The property has read.<br>
	 *
	 * Example:
	 * @code
	 * // Predefined initialization function which is called once to initialize this script.
	 * function onOceanInitialize(engine, timestamp)
	 * {
	 *     var sceneNode = ocean.sceneDescription.findNode("NODE");
	 *
	 *     if (sceneNode.isValid())
	 *         ocean.info("The scene description node wrapps a ", sceneNode.type, " node");
	 * }
	 * @endcode
	 * @see SceneDescrptionManager::findNode().
	 */
	String type [get];

	/**
	 * Creates a new scene description node object.
	 * The object is not connected to an Ocean scene object by default.<br>
	 * @return New empty scene description node object
	 *
	 * Example:
	 * @code
	 * // Predefined initialization function which is called once to initialize this script.
	 * function onOceanInitialize(engine, timestamp)
	 * {
	 *    var node = new SceneDescriptionNode();
	 *
	 *    if (node.isInvalid())
	 *       ocean.info("A default scene description node object is not connected to an Ocean framework object.");
	 * }
	 * @endcode
	 * @see SceneDescriptionNode::isValid(), SceneDescriptionNode::isInvalid()
	 */
	SceneDescrptionNode();

	/**
	 * Returns the value of a specific field of this scene description node object.
	 * The type of the returning value depends on the type of the field.
	 * @param name Name of the field to return the value for
	 * @return Specified field value
	 * @see setField().
	 */
	Boolean field(String name);

	/**
	 * Returns the value of a specific field of this scene description node object.
	 * The type of the returning value depends on the type of the field.
	 * @param name Name of the field to return the value for
	 * @return Specified field value
	 * @see setField().
	 */
	Array<Boolean> field(String name);

	/**
	 * Returns the value of a specific field of this scene description node object.
	 * The type of the returning value depends on the type of the field.
	 * @param name Name of the field to return the value for
	 * @return Specified field value
	 * @see setField().
	 */
	Color field(String name);

	/**
	 * Returns the value of a specific field of this scene description node object.
	 * The type of the returning value depends on the type of the field.
	 * @param name Name of the field to return the value for
	 * @return Specified field value
	 * @see setField().
