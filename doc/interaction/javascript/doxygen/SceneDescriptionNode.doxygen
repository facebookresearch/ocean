	 * @see field().
	 */
	Boolean setField(String name, Array<Vector4> value, Number timestamp);

	/**
	 * Returns whether the scene description node object is connected to a Ocean framework node providing a specified field.
	 * @param name Name of the field to be checked
	 * @return True, if so
	 *
	 * Example:
	 * @code
	 * // Predefined initialization function which is called once to initialize this script.
	 * function onOceanInitialize(engine, timestamp)
	 * {
	 *     var sceneNode = ocean.sceneDescription.findNode("TRANSFORM");
	 *
	 *     if (sceneNode.isValid())
	 *     {
	 *         if (sceneNode.hasField("translation"))
	 *             sceneNode.setField("translation", new Vector3(10, 0, 0), timestamp);
	 *         else
	 *             ocean.warning("The scene description node with name 'TRANSFORM' does not provide a field with name 'translation'");
	 *     }
	 *     else
	 *         ocean.warning("A scene description node with name 'TRANSFORM' could not be found");
	 * }
	 * @endcode
	 */
	Boolean hasField(String name);

	/**
	 * Returns the type of a specified field of this scene description node object.
	 * Possible field types are: <b>INVALID, BOOLEAN, COLOR, NUMBER, INTEGER, MATRIX3, MATRIX4, SCENEDESCRIPTIONNODE, ROTATION, STRING, TIME, VECTOR2, VECTOR3, VECTOR4</b>.
	 * @param name Name of the field to return the field type for
	 * @return Type of the specified field, if the field does not exist INVALID is returned
	 *
	 * Example:
	 * @code
	 * // Predefined initialization function which is called once to initialize this script.
	 * function onOceanInitialize(engine, timestamp)
	 * {
	 *     var sceneNode = ocean.sceneDescription.findNode("TRANSFORM");
	 *
	 *     if (sceneNode.isValid())
	 *     {
	 *         if (sceneNode.fieldType("translation") == "VECTOR3")
	 *             sceneNode.setField("translation", new Vector3(10, 0, 0), timestamp);
	 *         else
	 *             ocean.warning("The scene description node with name 'TRANSFORM' does not provide a valid field with name 'translation'");
	 *     }
	 *     else
	 *         ocean.warning("A scene description node with name 'TRANSFORM' could not be found");
	 * }
	 * @endcode
	 */
	String fieldType(String name);

	 /**
	 * Returns the dimension of a specified field of this scene description node object.
	 * A field with a scalar value has dimension 0, a field with an array value has dimesion 1.
	 * @param name Name of the field to return the field dimension for
	 * @return Value dimension of the specified field, if the field does not exist -1 is returned
	 *
	 * Example:
	 * @code
	 * // Predefined initialization function which is called once to initialize this script.
	 * function onOceanInitialize(engine, timestamp)
	 * {
	 *     var sceneNode = ocean.sceneDescription.findNode("TRANSFORM");
	 *
	 *     if (sceneNode.isValid())
	 *     {
	 *         if (sceneNode.fieldDimension("translation") == 0)
	 *             sceneNode.setField("translation", new Vector3(10, 0, 0), timestamp);
	 *         else
	 *             ocean.warning("The scene description node with name 'TRANSFORM' does not provide a valid field with name 'translation'");
	 *     }
	 *     else
	 *         ocean.warning("A scene description node with name 'TRANSFORM' could not be found");
	 * }
	 * @endcode
	 */
	Integer fieldDimension(String name);

	/**
	 * Returns one of the parent node objects of this scene description node object.
	 * If a node has more than one parent an arbitary parent node object is returned.
	 * Beware: Check whether the returned object is connected to a valid Ocean framework object before usage!
	 * @return One parent scene description node object
	 * @see parents(), isValid().
	 */
	SceneDescriptionNode parent();

	 /**
	 * Returns all parent node objects of this scene description node object.
	 * @return All  parent scene description node objects
	 * @see parent(), isValid().
	 */
	Array<SceneDescriptionNode> parents();

	/**
	 * Returns whether this scene description node object is connected to a real object inside the Ocean framework.
	 * @return True, if the JavaScript object is connected with an Ocean framework object
	 */
	Boolean isValid();

	/**
	 * Returns whether this rendering object is not connected to a real object inside the Ocean framework.
	 * @return True, if the JavaScript object is not connected with an Ocean framework object
	 */
	Boolean isInvalid();
};
