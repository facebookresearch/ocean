<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Build Application Demo (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_applicationdemo_build_imported>True</ocean_applicationdemo_build_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_application_build_imported)' != 'True'" Project="..\application_build.props"/>
  </ImportGroup>

  <!-- IntDir for demo applications includes the demo category prefix (e.g., "demorendering", "demobase").
       The prefix is set by category-specific property sheets (e.g., application_demo_rendering_build.props)
       BEFORE they import this file. If no prefix is set, use just the project name. -->
  <PropertyGroup>
    <IntDir>$(OceanRootPath)bin\tmp\impl\application\ocean\demo\$(OceanDemoCategoryPrefix)$(ProjectName)\android\$(OceanConfigFolder)\</IntDir>
  </PropertyGroup>
</Project>
