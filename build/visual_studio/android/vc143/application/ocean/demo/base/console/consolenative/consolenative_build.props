<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Build Console Native Demo (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_consolenative_build_imported>True</ocean_consolenative_build_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_consolenative_common_imported)' != 'True'" Project="consolenative_common.props"/>
    <Import Condition="'$(ocean_consolenative_reference_imported)' != 'True'" Project="consolenative_reference.props"/>
  </ImportGroup>

  <PropertyGroup>
    <TargetName>OceanDemoBaseConsole</TargetName>
  </PropertyGroup>
</Project>
