<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Build PictureTaker Native Demo (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_picturetakernative_build_imported>True</ocean_picturetakernative_build_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_picturetakernative_common_imported)' != 'True'" Project="picturetakernative_common.props"/>
    <Import Condition="'$(ocean_picturetakernative_reference_imported)' != 'True'" Project="picturetakernative_reference.props"/>
  </ImportGroup>

  <PropertyGroup>
    <TargetName>OceanDemoCVCalibrationPictureTaker</TargetName>
  </PropertyGroup>
</Project>
