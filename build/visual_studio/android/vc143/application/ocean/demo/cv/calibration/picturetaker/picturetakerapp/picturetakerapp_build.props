<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Build PictureTaker App Demo (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_picturetakerapp_build_imported>True</ocean_picturetakerapp_build_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_picturetakerapp_common_imported)' != 'True'" Project="picturetakerapp_common.props"/>
    <Import Condition="'$(ocean_picturetakerapp_reference_imported)' != 'True'" Project="picturetakerapp_reference.props"/>
  </ImportGroup>
</Project>
