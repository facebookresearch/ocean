<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Renderer Native Demo (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_renderernative_common_imported>True</ocean_renderernative_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_applicationdemorendering_build_imported)' != 'True'" Project="..\..\application_demo_rendering_build.props"/>
    <Import Condition="'$(ocean_platformandroidapplicationjni_use_imported)' != 'True'" Project="..\..\..\..\..\..\ocean\platform\android\application\jni\platformandroidapplicationjni_use.props"/>
    <Import Condition="'$(ocean_renderingglescenegraphjni_use_imported)' != 'True'" Project="..\..\..\..\..\..\ocean\rendering\glescenegraph\jni\renderingglescenegraphjni_use.props"/>
  </ImportGroup>
</Project>
