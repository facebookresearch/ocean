<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Build Application Demo Rendering (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_applicationdemorendering_build_imported>True</ocean_applicationdemorendering_build_imported>
  </PropertyGroup>

  <!-- Set the demo category prefix for intermediate directory naming.
       This prefix is prepended to $(ProjectName) in the IntDir path.
       Must be defined BEFORE importing application_demo_build.props which uses it. -->
  <PropertyGroup>
    <OceanDemoCategoryPrefix>demorendering</OceanDemoCategoryPrefix>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_applicationdemo_build_imported)' != 'True'" Project="..\application_demo_build.props"/>
  </ImportGroup>

  <PropertyGroup>
    <OutDir>$(OceanRootPath)bin\application\ocean\demo\rendering\android\$(OceanConfigFolder)\</OutDir>
  </PropertyGroup>
</Project>
