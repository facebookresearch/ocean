<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Build Renderer App Demo (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_rendererapp_build_imported>True</ocean_rendererapp_build_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_rendererapp_common_imported)' != 'True'" Project="rendererapp_common.props"/>
    <Import Condition="'$(ocean_rendererapp_reference_imported)' != 'True'" Project="rendererapp_reference.props"/>
  </ImportGroup>
</Project>
