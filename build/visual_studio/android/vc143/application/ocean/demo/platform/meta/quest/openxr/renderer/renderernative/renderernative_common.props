<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Platform Meta Quest OpenXR Renderer Native Demo (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_renderernative_common_imported>True</ocean_renderernative_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_applicationdemoplatform_build_imported)' != 'True'" Project="..\..\..\..\..\application_demo_platform_build.props"/>
    <Import Condition="'$(ocean_platformmetaquestopenxrapplication_use_imported)' != 'True'" Project="..\..\..\..\..\..\..\..\..\ocean\platform\meta\quest\openxr\application\platformmetaquestopenxrapplication_use.props"/>
  </ImportGroup>
</Project>
