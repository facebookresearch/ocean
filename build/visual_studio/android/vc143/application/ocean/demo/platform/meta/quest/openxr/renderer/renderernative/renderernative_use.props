<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Use Platform Meta Quest OpenXR Renderer Native Demo (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_renderernative_use_imported>True</ocean_renderernative_use_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_renderernative_common_imported)' != 'True'" Project="renderernative_common.props"/>
  </ImportGroup>

  <!-- Compute the output directory for this shared library.
       Use OceanSharedLibConfigFolder if available (set by application_build.props for app projects),
       otherwise fall back to OceanConfigFolder (for native library projects referencing each other). -->
  <PropertyGroup>
    <_RenderernativeOutDir Condition="'$(OceanSharedLibConfigFolder)' != ''">$(OceanRootPath)bin\application\ocean\demo\platform\android\$(OceanSharedLibConfigFolder)\</_RenderernativeOutDir>
    <_RenderernativeOutDir Condition="'$(_RenderernativeOutDir)' == ''">$(OceanRootPath)bin\application\ocean\demo\platform\android\$(OceanConfigFolder)\</_RenderernativeOutDir>
  </PropertyGroup>

  <ItemGroup Condition="$(Configuration.Contains('Debug'))">
    <OceanNativeSharedLibrary Include="$(_RenderernativeOutDir)libOceanDemoPlatformMetaQuestOpenXRRendererApplication.so" />
    <OceanNativeSharedLibrary Include="$(_RenderernativeOutDir)libc++_shared.so" />
  </ItemGroup>
  <PropertyGroup Condition="$(Configuration.Contains('Debug'))">
    <OceanNativeSharedLibraries>$(OceanNativeSharedLibraries);libOceanDemoPlatformMetaQuestOpenXRRendererApplication.so;libc++_shared.so</OceanNativeSharedLibraries>
  </PropertyGroup>

  <ItemGroup Condition="!$(Configuration.Contains('Debug'))">
    <OceanNativeSharedLibrary Include="$(_RenderernativeOutDir)libOceanDemoPlatformMetaQuestOpenXRRendererApplication.so" />
    <OceanNativeSharedLibrary Include="$(_RenderernativeOutDir)libc++_shared.so" />
  </ItemGroup>
  <PropertyGroup Condition="!$(Configuration.Contains('Debug'))">
    <OceanNativeSharedLibraries>$(OceanNativeSharedLibraries);libOceanDemoPlatformMetaQuestOpenXRRendererApplication.so;libc++_shared.so</OceanNativeSharedLibraries>
  </PropertyGroup>
</Project>
