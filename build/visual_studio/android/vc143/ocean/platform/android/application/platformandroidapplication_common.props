<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Ocean Platform Android Application (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_platformandroidapplication_common_imported>True</ocean_platformandroidapplication_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_common_imported)' != 'True'" Project="..\..\..\..\ocean_common.props"/>
    <Import Condition="'$(ocean_platformandroid_use_imported)' != 'True'" Project="..\platformandroid_use.props"/>
    <Import Condition="'$(ocean_platformgles_use_imported)' != 'True'" Project="..\..\gles\platformgles_use.props"/>
    <Import Condition="'$(ocean_rendering_use_imported)' != 'True'" Project="..\..\..\rendering\rendering_use.props"/>
  </ImportGroup>
</Project>
