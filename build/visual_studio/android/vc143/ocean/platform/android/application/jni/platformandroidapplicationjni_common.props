<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Ocean Platform Android Application JNI (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_platformandroidapplicationjni_common_imported>True</ocean_platformandroidapplicationjni_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_common_imported)' != 'True'" Project="..\..\..\..\..\ocean_common.props"/>
    <Import Condition="'$(ocean_basejni_use_imported)' != 'True'" Project="..\..\..\..\base\jni\basejni_use.props"/>
	<Import Condition="'$(ocean_platformandroid_use_imported)' != 'True'" Project="..\..\platformandroid_use.props"/>
    <Import Condition="'$(ocean_platformandroidapplication_use_imported)' != 'True'" Project="..\platformandroidapplication_use.props"/>
  </ImportGroup>
</Project>
