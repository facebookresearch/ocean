<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Use Ocean Platform Android Application (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_platformandroidapplication_use_imported>True</ocean_platformandroidapplication_use_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_platformandroidapplication_common_imported)' != 'True'" Project="platformandroidapplication_common.props"/>
  </ImportGroup>

  <!-- Link against the library -->
  <ItemDefinitionGroup Condition="$(Configuration.Contains('Debug'))">
    <Link>
      <AdditionalDependencies>OceanPlatformAndroidApplicationD;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="!$(Configuration.Contains('Debug'))">
    <Link>
      <AdditionalDependencies>OceanPlatformAndroidApplication;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
</Project>
