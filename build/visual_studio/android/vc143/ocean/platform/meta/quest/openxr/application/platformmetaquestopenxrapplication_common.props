<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Ocean Platform Meta Quest OpenXR Application (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_platformmetaquestopenxrapplication_common_imported>True</ocean_platformmetaquestopenxrapplication_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_common_imported)' != 'True'" Project="..\..\..\..\..\..\ocean_common.props"/>
    <Import Condition="'$(ocean_base_use_imported)' != 'True'" Project="..\..\..\..\..\base\base_use.props"/>
    <Import Condition="'$(ocean_platform_use_imported)' != 'True'" Project="..\..\..\..\platform_use.props"/>
    <Import Condition="'$(ocean_platformlinux_use_imported)' != 'True'" Project="..\..\..\..\linux\platformlinux_use.props"/>
    <Import Condition="'$(ocean_platformandroid_use_imported)' != 'True'" Project="..\..\..\..\android\platformandroid_use.props"/>
    <Import Condition="'$(ocean_platformopenxr_use_imported)' != 'True'" Project="..\..\..\..\openxr\platformopenxr_use.props"/>
    <Import Condition="'$(ocean_platformmetaquest_use_imported)' != 'True'" Project="..\..\platformmetaquest_use.props"/>
    <Import Condition="'$(ocean_platformmetaquestopenxr_use_imported)' != 'True'" Project="..\platformmetaquestopenxr_use.props"/>
    <Import Condition="'$(ocean_renderingglescenegraphquestopenxr_use_imported)' != 'True'" Project="..\..\..\..\..\rendering\glescenegraph\quest\openxr\renderingglescenegraphquestopenxr_use.props"/>
  </ImportGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>$(OceanRootPath)3rdparty\android_native_app_glue\h\android;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Static Debug' Or '$(Configuration)'=='Shared Debug'">
    <Link>
      <AdditionalLibraryDirectories>$(OceanRootPath)3rdparty\android_native_app_glue\lib\$(Ocean3rdPartyConfigFolder);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalOptions>-Wl,--whole-archive -Wl,-Bstatic -lnative_app_glue -Wl,-Bdynamic -Wl,--no-whole-archive %(AdditionalOptions)</AdditionalOptions>
    </Link>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Static Release' Or '$(Configuration)'=='Shared Release'">
    <Link>
      <AdditionalLibraryDirectories>$(OceanRootPath)3rdparty\android_native_app_glue\lib\$(Ocean3rdPartyConfigFolder);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalOptions>-Wl,--whole-archive -Wl,-Bstatic -lnative_app_glue -Wl,-Bdynamic -Wl,--no-whole-archive %(AdditionalOptions)</AdditionalOptions>
    </Link>
  </ItemDefinitionGroup>
</Project>
