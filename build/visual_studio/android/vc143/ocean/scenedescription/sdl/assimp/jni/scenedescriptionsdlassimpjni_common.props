<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Ocean SceneDescription SDL Assimp JNI (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_scenedescriptionsdlassimpjni_common_imported>True</ocean_scenedescriptionsdlassimpjni_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_common_imported)' != 'True'" Project="..\..\..\..\..\ocean_common.props"/>
	<Import Condition="'$(ocean_scenedescriptionsdlassimp_use_imported)' != 'True'" Project="..\scenedescriptionsdlassimp_use.props"/>
  </ImportGroup>
</Project>
