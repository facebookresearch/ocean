<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Ocean SceneDescription SDL Assimp (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_scenedescriptionsdlassimp_common_imported>True</ocean_scenedescriptionsdlassimp_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_common_imported)' != 'True'" Project="..\..\..\..\ocean_common.props"/>
    <Import Condition="'$(ocean_base_use_imported)' != 'True'" Project="..\..\..\base\base_use.props"/>
    <Import Condition="'$(ocean_cv_use_imported)' != 'True'" Project="..\..\..\cv\cv_use.props"/>
    <Import Condition="'$(ocean_io_use_imported)' != 'True'" Project="..\..\..\io\io_use.props"/>
    <Import Condition="'$(ocean_math_use_imported)' != 'True'" Project="..\..\..\math\math_use.props"/>
    <Import Condition="'$(ocean_media_use_imported)' != 'True'" Project="..\..\..\media\media_use.props"/>
    <Import Condition="'$(ocean_scenedescription_use_imported)' != 'True'" Project="..\..\scenedescription_use.props"/>
  </ImportGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>$(OceanRootPath)3rdparty\assimp\h\android;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
  </ItemDefinitionGroup>

  <!-- Link against Assimp debug library -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Static Debug' Or '$(Configuration)'=='Shared Debug'">
    <Link>
      <AdditionalLibraryDirectories>$(OceanRootPath)3rdparty\assimp\lib\android_arm64_static_debug;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>assimpd;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <!-- Link against Assimp release library -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Static Release' Or '$(Configuration)'=='Shared Release'">
    <Link>
      <AdditionalLibraryDirectories>$(OceanRootPath)3rdparty\assimp\lib\android_arm64_static;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>assimp;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
</Project>
