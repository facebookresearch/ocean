<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Build Ocean Rendering GLESceneGraph Quest OpenXR (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_renderingglescenegraphquestopenxr_build_imported>True</ocean_renderingglescenegraphquestopenxr_build_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_renderingglescenegraphquestopenxr_common_imported)' != 'True'" Project="renderingglescenegraphquestopenxr_common.props"/>
    <Import Condition="'$(ocean_renderingglescenegraphquestopenxr_reference_imported)' != 'True'" Project="renderingglescenegraphquestopenxr_reference.props"/>
    <Import Condition="'$(ocean_library_build_imported)' != 'True'" Project="..\..\..\..\ocean_library_build.props"/>
  </ImportGroup>

  <!-- Target name for Debug configurations -->
  <PropertyGroup Condition="'$(Configuration)'=='Static Debug' Or '$(Configuration)'=='Shared Debug'">
    <TargetName>OceanRenderingGLESceneGraphQuestOpenXRD</TargetName>
  </PropertyGroup>

  <!-- Target name for Release configurations -->
  <PropertyGroup Condition="'$(Configuration)'=='Static Release' Or '$(Configuration)'=='Shared Release'">
    <TargetName>OceanRenderingGLESceneGraphQuestOpenXR</TargetName>
  </PropertyGroup>
</Project>
