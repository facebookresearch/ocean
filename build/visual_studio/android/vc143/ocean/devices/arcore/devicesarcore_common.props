<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Ocean Devices ARCore (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_devices_arcore_common_imported>True</ocean_devices_arcore_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_common_imported)' != 'True'" Project="..\..\..\ocean_common.props"/>
    <Import Condition="'$(ocean_base_use_imported)' != 'True'" Project="..\..\base\base_use.props"/>
    <Import Condition="'$(ocean_cv_use_imported)' != 'True'" Project="..\..\cv\cv_use.props"/>
    <Import Condition="'$(ocean_cv_segmentation_use_imported)' != 'True'" Project="..\..\cv\segmentation\cvsegmentation_use.props"/>
    <Import Condition="'$(ocean_devices_use_imported)' != 'True'" Project="..\devices_use.props"/>
    <Import Condition="'$(ocean_math_use_imported)' != 'True'" Project="..\..\math\math_use.props"/>
    <Import Condition="'$(ocean_media_android_use_imported)' != 'True'" Project="..\..\media\android\mediaandroid_use.props"/>
    <Import Condition="'$(ocean_platform_android_use_imported)' != 'True'" Project="..\..\platform\android\platformandroid_use.props"/>
  </ImportGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>$(OceanRootPath)3rdparty\arcore-android-sdk\h\android;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
