<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Ocean Devices ARCore JNI (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_devicesarcorejni_common_imported>True</ocean_devicesarcorejni_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_common_imported)' != 'True'" Project="..\..\..\..\ocean_common.props"/>
	<Import Condition="'$(ocean_devicesarcore_use_imported)' != 'True'" Project="..\..\..\devices\arcore\devicesarcore_use.props"/>
  </ImportGroup>
</Project>
