<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Ocean Media OpenImageLibraries JNI (Common, Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_mediaopenimagelibrariesjni_common_imported>True</ocean_mediaopenimagelibrariesjni_common_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_common_imported)' != 'True'" Project="..\..\..\..\ocean_common.props"/>
	<Import Condition="'$(ocean_mediaopenimagelibraries_use_imported)' != 'True'" Project="..\..\..\media\openimagelibraries\mediaopenimagelibraries_use.props"/>
  </ImportGroup>
</Project>
