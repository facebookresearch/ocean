<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Use Ocean Media Android JNI (Android)</_PropertySheetDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <ocean_mediaandroidjni_use_imported>True</ocean_mediaandroidjni_use_imported>
  </PropertyGroup>

  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_mediaandroidjni_common_imported)' != 'True'" Project="mediaandroidjni_common.props"/>
  </ImportGroup>

  <!-- Link against debug JNI library with whole-archive (force static linking) -->
  <ItemDefinitionGroup Condition="$(Configuration.Contains('Debug'))">
    <Link>
      <AdditionalOptions>-Wl,--whole-archive -Wl,-Bstatic -lOceanMediaAndroidJniD -Wl,-Bdynamic -Wl,--no-whole-archive %(AdditionalOptions)</AdditionalOptions>
    </Link>
  </ItemDefinitionGroup>

  <!-- Link against release JNI library with whole-archive (force static linking) -->
  <ItemDefinitionGroup Condition="!$(Configuration.Contains('Debug'))">
    <Link>
      <AdditionalOptions>-Wl,--whole-archive -Wl,-Bstatic -lOceanMediaAndroidJni -Wl,-Bdynamic -Wl,--no-whole-archive %(AdditionalOptions)</AdditionalOptions>
    </Link>
  </ItemDefinitionGroup>
</Project>
