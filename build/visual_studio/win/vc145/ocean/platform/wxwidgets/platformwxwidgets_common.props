<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_PropertySheetDisplayName>Ocean Platform WxWidgets (Common)</_PropertySheetDisplayName>
  </PropertyGroup>
  <PropertyGroup>
    <ocean_platformwxwidgets_common_imported>True</ocean_platformwxwidgets_common_imported>
  </PropertyGroup>
  <ImportGroup Label="Dependencies">
    <Import Condition="'$(ocean_common_imported)' != 'True'" Project="..\..\..\ocean_common.props"/>
    <Import Condition="'$(ocean_base_use_imported)' != 'True'" Project="..\..\base\base_use.props"/>
    <Import Condition="'$(ocean_cv_use_imported)' != 'True'" Project="..\..\cv\cv_use.props"/>
    <Import Condition="'$(ocean_io_use_imported)' != 'True'" Project="..\..\io\io_use.props"/>
    <Import Condition="'$(ocean_media_use_imported)' != 'True'" Project="..\..\media\media_use.props"/>
    <Import Condition="'$(ocean_platform_use_imported)' != 'True'" Project="..\..\platform\platform_use.props"/>
  </ImportGroup>
  <ItemDefinitionGroup Condition="$(Configuration.StartsWith('Shared'))">
    <ClCompile>
      <PreprocessorDefinitions>WXUSINGDLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>
  <!-- Include paths need the lib-specific setup.h folder before the msvc wrapper to bypass wxWidgets' hardcoded relative paths -->
  <!-- Static Debug -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Static Debug'">
    <ClCompile>
      <AdditionalIncludeDirectories>$(OceanRootPath)3rdparty\wxwidgets\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\wxwidgets\h\win;$(OceanRootPath)3rdparty\wxwidgets\h\win\msvc;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <AdditionalDependencies>wxbase33ud.lib;wxmsw33ud_core.lib;libpng16_staticd.lib;zlibstaticd.lib;Comctl32.lib;Rpcrt4.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(OceanRootPath)3rdparty\wxwidgets\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\libpng\lib\$(Ocean3rdPartyConfigFolder);$(OceanRootPath)3rdparty\zlib\lib\$(Ocean3rdPartyConfigFolder);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>
  <!-- Shared Debug -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Shared Debug'">
    <ClCompile>
      <AdditionalIncludeDirectories>$(OceanRootPath)3rdparty\wxwidgets\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\wxwidgets\h\win;$(OceanRootPath)3rdparty\wxwidgets\h\win\msvc;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <AdditionalDependencies>wxbase33ud.lib;wxmsw33ud_core.lib;Comctl32.lib;Rpcrt4.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(OceanRootPath)3rdparty\wxwidgets\lib\$(OceanConfigFolder);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>
  <!-- Static Profile/Release -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Static Profile' Or '$(Configuration)'=='Static Release'">
    <ClCompile>
      <AdditionalIncludeDirectories>$(OceanRootPath)3rdparty\wxwidgets\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\wxwidgets\h\win;$(OceanRootPath)3rdparty\wxwidgets\h\win\msvc;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <AdditionalDependencies>wxbase33u.lib;wxmsw33u_core.lib;libpng16_static.lib;zlibstatic.lib;Comctl32.lib;Rpcrt4.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(OceanRootPath)3rdparty\wxwidgets\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\libpng\lib\$(Ocean3rdPartyConfigFolder);$(OceanRootPath)3rdparty\zlib\lib\$(Ocean3rdPartyConfigFolder);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>
  <!-- Shared Profile/Release -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Shared Profile' Or '$(Configuration)'=='Shared Release'">
    <ClCompile>
      <AdditionalIncludeDirectories>$(OceanRootPath)3rdparty\wxwidgets\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\wxwidgets\h\win;$(OceanRootPath)3rdparty\wxwidgets\h\win\msvc;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <AdditionalDependencies>wxbase33u.lib;wxmsw33u_core.lib;Comctl32.lib;Rpcrt4.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(OceanRootPath)3rdparty\wxwidgets\lib\$(OceanConfigFolder);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>

  <!-- Append wxWidgets shared DLL directory and its zlib dependency to the debugger PATH for Shared builds -->
  <PropertyGroup Condition="$(Configuration.StartsWith('Shared'))">
    <OceanSharedLibPaths>$(OceanSharedLibPaths);$(OceanRootPath)3rdparty\wxwidgets\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\zlib\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\libpng\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\libjpeg-turbo\lib\$(OceanConfigFolder);$(OceanRootPath)3rdparty\libtiff\lib\$(OceanConfigFolder)</OceanSharedLibPaths>
    <LocalDebuggerEnvironment>PATH=$(OceanSharedLibPaths);%PATH%</LocalDebuggerEnvironment>
  </PropertyGroup>
</Project>
